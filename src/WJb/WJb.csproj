<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <AssemblyName>WJb</AssemblyName>
        <RootNamespace>WJb</RootNamespace>
        <PackageId>WJb</PackageId>
        <SignAssembly>True</SignAssembly>
        <AssemblyOriginatorKeyFile>..\..\..\UkrGuru.snk</AssemblyOriginatorKeyFile>
        <Company>PE VIKTOR Oleksandr Oleksandrovych</Company>
        <Authors>UkrGuru</Authors>
        <Copyright>PE VIKTOR Oleksandr Oleksandrovych</Copyright>
        <PackageProjectUrl>https://github.com/UkrGuru/WJb</PackageProjectUrl>
        <Version>0.25.0-beta.3</Version>
        <PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
        <PackageLicenseFile>LICENSE</PackageLicenseFile>
        <PackageIcon>ukrguru-logo.jpg</PackageIcon>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <Description>WJb is a lightweight and flexible background job execution library for .NET, built for simplicity and scalability. It provides priority-based queues, JSON payload handling, scheduled jobs using standard cron syntax, and seamless integration with dependency injection and hosted services. Perfect for modern .NET applications that require structured, efficient background processing.</Description>
        <RepositoryUrl>https://github.com/UkrGuru/WJb</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageReleaseNotes>
            v0.25.0
            - Initial public API contract frozen (api-v0.25.0)
            - Core job execution, priority, delayed jobs, and chaining supported
            - Samples aligned with production semantics
        </PackageReleaseNotes>
        <PackageTags>webjobs</PackageTags>
        <IncludeSymbols>False</IncludeSymbols>
        <SymbolPackageFormat>snupkg</SymbolPackageFormat>
        <DebugType>embedded</DebugType>
        <PublishRepositoryUrl>true</PublishRepositoryUrl>
        <EmbedUntrackedSources>true</EmbedUntrackedSources>
        <EnableSourceLink>true</EnableSourceLink>
        <GenerateDocumentationFile>False</GenerateDocumentationFile>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
    </PropertyGroup>
    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
        <DebugType>none</DebugType>
    </PropertyGroup>
    <ItemGroup>
      <Compile Remove="Extensions\ActionItemFactory.cs" />
    </ItemGroup>
    <ItemGroup>
        <EmbeddedResource Include="..\..\LICENSE">
            <Pack>True</Pack>
            <PackagePath></PackagePath>
        </EmbeddedResource>
        <EmbeddedResource Include="..\..\ukrguru-logo.jpg">
            <Pack>True</Pack>
            <PackagePath></PackagePath>
        </EmbeddedResource>
        <EmbeddedResource Include="..\..\README.md">
            <Pack>True</Pack>
            <PackagePath>\</PackagePath>
        </EmbeddedResource>
    </ItemGroup>
    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" Version="10.0.5" />
        <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.5" />
        <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" Version="10.0.5" />
    </ItemGroup>
    <ItemGroup>
        <Using Include="System" />
        <Using Include="System.Linq" />
    </ItemGroup>
</Project>
